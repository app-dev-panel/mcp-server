#!/usr/bin/env php
<?php

declare(strict_types=1);

/**
 * ADP MCP Server — standalone entry point.
 *
 * Starts an MCP server over stdio that exposes ADP debug data to AI assistants.
 *
 * Usage:
 *   php bin/adp-mcp --storage=/path/to/debug-data
 *
 * Environment variables:
 *   ADP_STORAGE_PATH — Path to debug data storage directory
 */

// Find autoloader. `$GLOBALS['_composer_autoload_path']` is set by the Composer-generated
// bin proxy (vendor/bin/adp-mcp) and points at vendor/autoload.php directly — prefer it when
// available so we don't have to juggle relative paths across install layouts.
$autoloaded = false;
if (isset($GLOBALS['_composer_autoload_path']) && file_exists((string) $GLOBALS['_composer_autoload_path'])) {
    require (string) $GLOBALS['_composer_autoload_path'];
    $autoloaded = true;
} else {
    $autoloadPaths = [
        __DIR__ . '/../../../autoload.php',          // Composer install: vendor/app-dev-panel/mcp-server/bin/ → vendor/autoload.php
        __DIR__ . '/../../../vendor/autoload.php',   // Monorepo: libs/McpServer/bin/ → vendor/autoload.php
        __DIR__ . '/../vendor/autoload.php',         // Standalone checkout with its own vendor/
    ];
    foreach ($autoloadPaths as $autoloadPath) {
        if (!file_exists($autoloadPath)) {
            continue;
        }
        require $autoloadPath;
        $autoloaded = true;
        break;
    }
}

if (!$autoloaded) {
    fwrite(STDERR, "Autoloader not found. Run composer install.\n");
    exit(1);
}

use AppDevPanel\Kernel\DebuggerIdGenerator;
use AppDevPanel\Kernel\Storage\FileStorage;
use AppDevPanel\McpServer\Inspector\InspectorClient;
use AppDevPanel\McpServer\McpServer;
use AppDevPanel\McpServer\McpToolRegistryFactory;
use AppDevPanel\McpServer\Transport\StdioTransport;

// Parse --storage=PATH and --inspector-url=URL from argv
$storagePath = getenv('ADP_STORAGE_PATH') ?: null;
$inspectorUrl = getenv('ADP_INSPECTOR_URL') ?: null;

foreach ($argv as $arg) {
    if (str_starts_with($arg, '--storage=')) {
        $storagePath = substr($arg, strlen('--storage='));
    }
    if (str_starts_with($arg, '--inspector-url=')) {
        $inspectorUrl = substr($arg, strlen('--inspector-url='));
    }
}

if ($storagePath === null || $storagePath === '') {
    $storagePath = sys_get_temp_dir() . '/adp';
}

if (!is_dir($storagePath)) {
    fwrite(STDERR, sprintf("Storage path does not exist: %s\n", $storagePath));
    exit(1);
}

// Bootstrap
$storage = new FileStorage($storagePath, new DebuggerIdGenerator());
$inspectorClient = is_string($inspectorUrl) && $inspectorUrl !== ''
    ? new InspectorClient($inspectorUrl)
    : null;
$toolRegistry = McpToolRegistryFactory::create($storage, $inspectorClient);

$transport = new StdioTransport();
$server = new McpServer($toolRegistry, $transport);

fwrite(STDERR, sprintf("ADP MCP server started (storage: %s", $storagePath));
if ($inspectorClient !== null) {
    fwrite(STDERR, sprintf(", inspector: %s", $inspectorUrl));
}
fwrite(STDERR, ")\n");

$server->run();
